#!/usr/bin/env zsh

# jira - move a Jira Data Center ticket between workflow stages via a simple TUI.
#
# Usage:
#   jira                 # detect ticket from current git branch (e.g. release/JIRA-0123)
#   jira TICKET-0123     # use the given ticket key
#   jira -v <vault>      # override the 1Password vault (default: Skatteetaten)
#   jira -i <item>       # override the 1Password item  (default: Jira)
#
# Configuration (all overridable via environment):
#   JIRA_VAULT          1Password vault holding the Jira item   (default: Skatteetaten)
#   JIRA_ITEM           1Password item holding the Jira config  (default: Jira)
#   JIRA_URL            Jira base URL. If unset, read from 1Password (see JIRA_URL_OP_REF)
#   JIRA_TOKEN          Jira Personal Access Token. If unset, read from 1Password
#   JIRA_URL_OP_REF     op:// reference for the URL    (default: op://$VAULT/$ITEM/url)
#   JIRA_TOKEN_OP_REF   op:// reference for the token  (default: op://$VAULT/$ITEM/token)
#
# Requires: curl, jq, op (1Password CLI, signed in).

set -u
emulate -L zsh

# --- Workflow definition -----------------------------------------------------
# Linear flow; "Lukket" is always reachable from any stage.
# The actual FLOW is selected later based on the ticket's issue type.
typeset -a FLOW
CLOSED="Lukket"

# --- Defaults ----------------------------------------------------------------
VAULT="${JIRA_VAULT:-Skatteetaten}"
ITEM="${JIRA_ITEM:-Jira}"
TICKET=""

# --- Helpers -----------------------------------------------------------------
err() { print -u2 -- "jira: $*"; }

usage() {
	cat <<EOF
Usage: jira [-v <vault>] [-i <item>] [TICKET-KEY]

  -v, --vault <vault>   1Password vault to read Jira config from (default: Skatteetaten)
  -i, --item <item>     1Password item to read Jira config from (default: Jira)
  -h, --help            Show this help

If TICKET-KEY is omitted, it is detected from the current git branch
(e.g. release/JIRA-0123 -> JIRA-0123).
EOF
}

# --- Argument parsing --------------------------------------------------------
while (( $# )); do
	case "$1" in
		-v|--vault)
			[[ -n "${2:-}" ]] || { err "missing value for $1"; exit 1; }
			VAULT="$2"; shift 2 ;;
		-i|--item)
			[[ -n "${2:-}" ]] || { err "missing value for $1"; exit 1; }
			ITEM="$2"; shift 2 ;;
		-h|--help)
			usage; exit 0 ;;
		-*)
			err "unknown option: $1"; usage; exit 1 ;;
		*)
			[[ -z "$TICKET" ]] || { err "unexpected argument: $1"; exit 1; }
			TICKET="$1"; shift ;;
	esac
done

# --- Dependency checks -------------------------------------------------------
for bin in curl jq op; do
	if ! command -v "$bin" &>/dev/null; then
		err "'$bin' is required but not installed"
		exit 1
	fi
done

if ! op account list &>/dev/null; then
	err "1Password CLI is not signed in. Run: eval \$(op signin)"
	exit 1
fi

# --- Resolve credentials -----------------------------------------------------
JIRA_URL_OP_REF="${JIRA_URL_OP_REF:-op://$VAULT/$ITEM/url}"
JIRA_TOKEN_OP_REF="${JIRA_TOKEN_OP_REF:-op://$VAULT/$ITEM/token}"

if [[ -z "${JIRA_URL:-}" ]]; then
	if ! JIRA_URL="$(op read "$JIRA_URL_OP_REF" 2>/dev/null)"; then
		err "could not read Jira URL from 1Password ($JIRA_URL_OP_REF)"
		err "set \$JIRA_URL or fix the item/vault (vault: $VAULT, item: $ITEM)"
		exit 1
	fi
fi
if [[ -z "${JIRA_TOKEN:-}" ]]; then
	if ! JIRA_TOKEN="$(op read "$JIRA_TOKEN_OP_REF" 2>/dev/null)"; then
		err "could not read Jira token from 1Password ($JIRA_TOKEN_OP_REF)"
		err "set \$JIRA_TOKEN or fix the item/vault (vault: $VAULT, item: $ITEM)"
		exit 1
	fi
fi
JIRA_URL="${JIRA_URL%/}"

# --- Ticket detection --------------------------------------------------------
if [[ -z "$TICKET" ]]; then
	if branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null)"; then
		# Same pattern as .config/lazygit/config.yml
		if [[ "$branch" =~ '[A-Z]+-[0-9]+' ]]; then
			TICKET="$MATCH"
		fi
	fi
fi

if [[ -z "$TICKET" ]]; then
	err "no ticket given and none found in current branch"
	err "pass one explicitly, e.g.: jira TICKET-0123"
	exit 1
fi

if [[ ! "$TICKET" =~ '^[A-Z]+-[0-9]+$' ]]; then
	err "invalid ticket key: $TICKET"
	exit 1
fi

# --- Jira API ----------------------------------------------------------------
API="$JIRA_URL/rest/api/2"

# api_get <path> -> writes body to stdout, returns curl/HTTP status via $HTTP_CODE
jira_get() {
	local endpoint="$1" out
	out="$(curl -sS -w $'\n%{http_code}' \
		-H "Authorization: Bearer $JIRA_TOKEN" \
		-H "Accept: application/json" \
		"$API/$endpoint")" || return 1
	HTTP_CODE="${out##*$'\n'}"
	BODY="${out%$'\n'*}"
	[[ "$HTTP_CODE" == 2* ]]
}

jira_post() {
	local endpoint="$1" data="$2" out
	out="$(curl -sS -w $'\n%{http_code}' -X POST \
		-H "Authorization: Bearer $JIRA_TOKEN" \
		-H "Accept: application/json" \
		-H "Content-Type: application/json" \
		--data "$data" \
		"$API/$endpoint")" || return 1
	HTTP_CODE="${out##*$'\n'}"
	BODY="${out%$'\n'*}"
	[[ "$HTTP_CODE" == 2* ]]
}

# Fetch current status + summary
if ! jira_get "issue/$TICKET?fields=status,summary,issuetype"; then
	case "$HTTP_CODE" in
		401) err "authentication failed (401) - check your Jira token" ;;
		403) err "forbidden (403) - token lacks permission for $TICKET" ;;
		404) err "ticket not found (404): $TICKET" ;;
		*)   err "failed to fetch $TICKET (HTTP ${HTTP_CODE:-?})" ;;
	esac
	exit 1
fi

CURRENT="$(print -r -- "$BODY" | jq -r '.fields.status.name')"
SUMMARY="$(print -r -- "$BODY" | jq -r '.fields.summary')"
ISSUETYPE="$(print -r -- "$BODY" | jq -r '.fields.issuetype.name')"

if [[ -z "$CURRENT" || "$CURRENT" == "null" ]]; then
	err "could not determine current status of $TICKET"
	exit 1
fi

# Select the workflow based on issue type (case-insensitive).
if [[ "${ISSUETYPE:l}" == "admin oppgave" ]]; then
	FLOW=("Ny" "I gang" "QA" "Lukket")
else
	FLOW=("Ny" "Klar" "I gang" "QA" "Ferdig" "Lukket")
fi

# --- Compute valid targets ---------------------------------------------------
# Next stage forward in FLOW, plus a few backward moves, plus always Lukket.
typeset -a TARGETS
TARGETS=()

cur_idx=-1
for i in {1..${#FLOW}}; do
	[[ "${FLOW[$i]:l}" == "${CURRENT:l}" ]] && cur_idx=$i && break
done

if (( cur_idx > 0 && cur_idx < ${#FLOW} )); then
	next="${FLOW[$((cur_idx + 1))]}"
	[[ "$next" != "$CLOSED" ]] && TARGETS+=("$next")
fi
# Allowed backward moves (in addition to the forward step)
case "${CURRENT:l}" in
	klar)     TARGETS+=("Ny") ;;
	"i gang") TARGETS+=("Klar") ;;
	qa)       TARGETS+=("I gang") ;;
esac
# Always allow Lukket unless we are already there
[[ "${CURRENT:l}" != "${CLOSED:l}" ]] && TARGETS+=("$CLOSED")

if (( ${#TARGETS} == 0 )); then
	print -- "$TICKET is already at the final stage ($CURRENT). Nothing to do."
	exit 0
fi

# --- Resolve Jira transitions for the chosen target --------------------------
# Returns transition id (in $TRANSITION_ID) for a target status name, or fails.
resolve_transition() {
	local target="$1"
	if ! jira_get "issue/$TICKET/transitions"; then
		err "failed to fetch available transitions (HTTP ${HTTP_CODE:-?})"
		return 1
	fi
	TRANSITION_ID="$(print -r -- "$BODY" \
		| jq -r --arg name "$target" '.transitions[] | select((.to.name | ascii_downcase) == ($name | ascii_downcase)) | .id' \
		| head -n1)"
	[[ -n "$TRANSITION_ID" && "$TRANSITION_ID" != "null" ]]
}

# --- TUI ---------------------------------------------------------------------
DONE=false
trap cleanup INT
cleanup() {
	printf '\e[?25h'      # show cursor
	printf '\e[?1049l'    # restore screen
	exit 130
}

render_flow() {
	local out="" stage
	for stage in "${FLOW[@]}"; do
		[[ -n "$out" ]] && out+=" › "
		if [[ "${stage:l}" == "${CURRENT:l}" ]]; then
			out+=$'\e[1;33m['"$stage"$']\e[0m'
		else
			out+="$stage"
		fi
	done
	print -- "$out"
}

draw_menu() {
	local sel=$1 i line
	clear
	print -- "\e[1mTicket:\e[0m  $TICKET"
	print -- "\e[1mSummary:\e[0m $SUMMARY"
	print -- "\e[1mStatus:\e[0m  $(render_flow)"
	print --
	print -- "Move \e[1m$TICKET\e[0m to:"
	print --
	for i in {1..${#TARGETS}}; do
		if (( i == sel )); then
			print -- "  \e[7m ▸ ${TARGETS[$i]} \e[0m"
		else
			print -- "    ${TARGETS[$i]}"
		fi
	done
	print --
	print -- "\e[2m↑/↓ or j/k to move · Enter to select · 1-${#TARGETS} quick-pick · q to quit\e[0m"
}

printf '\e[?1049h'   # save screen
printf '\e[?25l'     # hide cursor

sel=1
choice=""
while ! $DONE; do
	draw_menu $sel
	# read a single keypress
	read -k 1 key
	case "$key" in
		$'\n'|$'\r')
			choice="${TARGETS[$sel]}"; DONE=true ;;
		q|Q)
			cleanup ;;
		j|J)
			(( sel < ${#TARGETS} )) && (( sel++ )) ;;
		k|K)
			(( sel > 1 )) && (( sel-- )) ;;
		[1-9])
			if (( key >= 1 && key <= ${#TARGETS} )); then
				choice="${TARGETS[$key]}"; sel=$key; DONE=true
			fi ;;
		$'\e')
			# arrow keys: ESC [ A/B
			read -k 1 -t 1 k2
			if [[ "$k2" == "[" ]]; then
				read -k 1 -t 1 k3
				case "$k3" in
					A) (( sel > 1 )) && (( sel-- )) ;;            # up
					B) (( sel < ${#TARGETS} )) && (( sel++ )) ;;  # down
				esac
			fi ;;
	esac
done

printf '\e[?25h'     # show cursor
printf '\e[?1049l'   # restore screen
trap - INT

[[ -z "$choice" ]] && exit 0

# --- Perform the transition --------------------------------------------------
print -- "Moving $TICKET: $CURRENT → $choice ..."

if ! resolve_transition "$choice"; then
	err "transition to '$choice' is not available in Jira for $TICKET"
	err "(its workflow may not allow this move from '$CURRENT')"
	exit 1
fi

if jira_post "issue/$TICKET/transitions" "{\"transition\":{\"id\":\"$TRANSITION_ID\"}}"; then
	print -- "\e[1;32m✓\e[0m $TICKET is now '$choice'"
else
	msg="$(print -r -- "$BODY" | jq -r '
		[ (.errorMessages[]?), (.errors | to_entries[]? | "\(.key): \(.value)") ] | join("; ")
	' 2>/dev/null)"
	err "transition failed (HTTP ${HTTP_CODE:-?})${msg:+: $msg}"
	exit 1
fi
